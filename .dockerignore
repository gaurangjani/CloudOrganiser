# Node / npm artefacts
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript build output (rebuilt inside Docker)
dist/
build/

# Environment files – never bake secrets into images
.env
.env.*

# Logs
logs/
*.log

# Test & coverage artefacts
coverage/
.nyc_output/

# IDE / OS metadata
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*~

# Git
.git
.gitignore

# CI / Docker files (not needed inside the image)
.github/
Dockerfile*
docker-compose*
.dockerignore

# Temporary files
tmp/
temp/
