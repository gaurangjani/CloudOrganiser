# Application Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session (IMPORTANT: Change this in production!)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Google OAuth (Optional - leave empty if not using)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Microsoft OAuth (Optional - leave empty if not using)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:3000/api/v1/auth/microsoft/callback

# AI Provider (Optional - defaults to 'local' rule-based classifier)
# Provider options: 'openai', 'azure-openai', 'local'
AI_PROVIDER=local

# API credentials (required for 'openai' and 'azure-openai' providers)
AI_API_KEY=

# Azure OpenAI endpoint (required for 'azure-openai' provider)
AI_ENDPOINT=

# Model or deployment name (e.g. 'gpt-4o-mini' for OpenAI, deployment name for Azure)
AI_MODEL=

# Optional AI tuning parameters
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.3
AI_TIMEOUT=30000
AI_RETRY_ATTEMPTS=3
